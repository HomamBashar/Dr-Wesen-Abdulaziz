# ==================================================
# Backend .env Configuration Example
# ==================================================

# Database Configuration
DATABASE_PATH=./data/clinic.db

# PIN Configuration
CLINIC_PIN=1234
SECRETARY_PIN=1234
DOCTOR_PIN=4321

# JWT Configuration (SECURITY: CHANGE THIS IN PRODUCTION!)
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://192.168.1.100:3000,http://127.0.0.1:3000

# Notes for Production:
# - Change JWT_SECRET_KEY to a strong random value
# - Use HTTPS in production
# - Restrict CORS_ORIGINS to your domain only
# - Use environment-specific .env files
